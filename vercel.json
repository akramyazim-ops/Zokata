{
    "version": 2,
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.js"
        },
        {
            "source": "/billplz/(.*)",
            "destination": "/api/server.js"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/api/server.js"
        }
    ]
}